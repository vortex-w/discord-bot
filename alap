
let selected_type = "";

function state_change(name, el, field_name = "key_value"){
    let value;

    if(el.type === "checkbox"){
        value = el.checked ? 1 : 0;
    }else{
        value = el.value;
    }

    var xhttp = new XMLHttpRequest();
    xhttp.onreadystatechange = function() {
        if(this.readyState == 4 && this.status == 200){
            if(this.responseText == "OK"){
                document.getElementById("msg").innerHTML = "Sikerült";
            }else{
                document.getElementById("msg").innerHTML = this.responseText;
                console.log(this.responseText);
            }
        }
    };

    xhttp.open("POST", "modulok/ajax/state_change_data.php", true);
    xhttp.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
    xhttp.send(
        "comm=state_change" +
        "&key_name=" + encodeURIComponent(name) +
        "&field_name=" + encodeURIComponent(field_name) +
        "&key_value=" + encodeURIComponent(value)
    );

    setTimeout(function(){
        document.getElementById("msg").innerHTML = "";
    }, 2000);
}

function select_type(){
    var type = document.getElementById("input_type").value;
    var divs = ["int", "string", "bool", "pin"];
    selected_type = type;

    for(let i = 0; i < divs.length; i++){
        if(type === divs[i]){
            document.getElementById(divs[i]).style.display = "block";
        }else{
            document.getElementById(divs[i]).style.display = "none";

            var nameInput = document.getElementById(divs[i] + "_name");
            if(nameInput){
                nameInput.value = "";
            }

            if(divs[i] !== "bool"){
                var valueInput = document.getElementById(divs[i] + "_value");
                if(valueInput){
                    valueInput.value = "";
                }
            }
        }
    }

    if(type !== "pin"){
        document.getElementById("pin_mode").value = "0";
    }
}

function save_variable(){
    if(selected_type === "" || selected_type === "0"){
        document.getElementById("variable_msg").innerHTML = "Válassz típust!";
        return;
    }

    var nameInput = document.getElementById(selected_type + "_name");
    var valueInput = document.getElementById(selected_type + "_value");

    if(!nameInput || !valueInput){
        document.getElementById("variable_msg").innerHTML = "Hiányzó mező!";
        return;
    }

    var name = nameInput.value;
    var value = valueInput.value;
    var pin_mode = "";

    if(selected_type === "pin"){
        pin_mode = document.getElementById("pin_mode").value;
    }

    var xhttp = new XMLHttpRequest();

    xhttp.onreadystatechange = function(){
        if(this.readyState == 4 && this.status == 200){
            if(this.responseText == "OK"){
                document.getElementById("variable_msg").innerHTML = "változó elmentve";
            }else{
                document.getElementById("variable_msg").innerHTML = this.responseText;
                console.log(this.responseText);
            }
        }
    };

    xhttp.open("POST", "modulok/ajax/save_variable.php", true);
    xhttp.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
    xhttp.send(
        "comm=save_variable" +
        "&variable_name=" + encodeURIComponent(name) +
        "&variable_type=" + encodeURIComponent(selected_type) +
        "&variable_value=" + encodeURIComponent(value) +
        "&pin_mode=" + encodeURIComponent(pin_mode)
    );

    setTimeout(function(){
        document.getElementById("variable_msg").innerHTML = "";
    }, 2000);

    setTimeout(function(){
        opened('content', 'robot', 'robot');
    }, 2500);
}
</script>
    {
        name: 'deletelog',
        description : 'Kitörli az összes, a legutolsó, vagy egy adott napi logot. Használat: !deletelog all | last | 2026-03-21',
        permissionLevel : 'admin',

        async prefix(message, args){
            const targetChannel = await getCommandTargetChannel(message, 'deletelog');
            const mode = (args[0] || "").trim();

            if(!mode){
                return targetChannel.send(
                    'Használat:\n' +
                    '!deletelog all\n' +
                    '!deletelog last\n' +
                    '!deletelog 2026-03-21'
                );
            }

            const dateRegex = /^\d{4}-\d{2}-\d{2}$/;

            try{
                if(mode === "all"){
                    const result = await deleteAllLogs();

                    await targetChannel.send(
                        `Az összes log törölve lett. Törölt elemek száma: **${result?.changes || 0}**`
                    );

                    await logInfo(
                        `Admin log törlés | mód: all | törlő: ${message.author.username} (${message.author.id})`,
                        "info"
                    );

                    return;
                }

                if(mode === "last"){
                    const lastLog = await getLastLog();

                    if(!lastLog){
                        return targetChannel.send("Nincs törölhető log bejegyzés.");
                    }

                    const result = await deleteLastLog();

                    if(!result || result.changes === 0){
                        return targetChannel.send("A legutolsó log törlése nem sikerült.");
                    }

                    await targetChannel.send(
                        `A legutolsó log törölve lett.\n` +
                        `ID: **${lastLog.id}**\n` +
                        `Típus: **${lastLog.type}**\n` +
                        `Dátum: **${lastLog.created_at}**`
                    );

                    await logInfo(
                        `Admin log törlés | mód: last | törölt log id: ${lastLog.id} | törlő: ${message.author.username} (${message.author.id})`,
                        "info"
                    );

                    return;
                }

                if(dateRegex.test(mode)){
                    const logs = await getLogsByDate(mode);

                    if(!logs || logs.length === 0){
                        return targetChannel.send(`Nincs log ezen a napon: **${mode}**`);
                    }

                    const result = await deleteLogsByDate(mode);

                    await targetChannel.send(
                        `A(z) **${mode}** napi logok törölve lettek. Törölt elemek száma: **${result?.changes || 0}**`
                    );

                    await logInfo(
                        `Admin log törlés | mód: dátum | dátum: ${mode} | törölt elemek: ${result?.changes || 0} | törlő: ${message.author.username} (${message.author.id})`,
                        "info"
                    );

                    return;
                }

                return targetChannel.send(
                    'Hibás paraméter.\n' +
                    'Használat:\n' +
                    '!deletelog all\n' +
                    '!deletelog last\n' +
                    '!deletelog 2026-03-21'
                );

            }catch(error){
                console.error("Hiba a deletelog parancsnál:", error);
                await logError(error, "Hiba a deletelog parancsnál");
                return targetChannel.send("Hiba történt a log törlése közben.");
            }
        }

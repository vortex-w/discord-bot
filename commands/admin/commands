const { logInfo, logError, logWarn, getLogsBetween } = require('../../database/logger');
module.exports = [
    {
        name: 'adminping',
        description: 'Admin ping teszt',
        permissionLevel: 'admin',

        async prefix(message, args) {
            await message.reply('admin pong');
        },

        async slash(interaction) {
            await interaction.reply('admin pong');
        }
    },
    {
        name: 'logteszt',
        description: 'Létre hoz egy log info bejegyzést az adatbázisban a logolás tesztelésével.',
        permissionLevel: 'admin',
        async prefix(message,args){
            await logInfo('Teszt üzenet',{
                user_id: message.author.id,
                user_name: message.author.username,
                guild_id: message.guild.id,
                guild_name: message.guild.name
            });
            await message.reply('Log bejegyzés létrehozva.');
        },
        async slash(interaction){
            await interaction.reply({
                content : 'Log bejegyzés létrehozva',
                ephemeral : true
            });
            await logInfo('Teszt üzenet',{
                user_id: interaction.user.id,

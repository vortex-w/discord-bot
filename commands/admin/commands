            if(!level){
                return message.reply("Adj meg egy jogosultsági szintent.");
            }
            if(!allowedLevels.includes(level)){
                return message.reply("Érvénytelen jogosultsági szint. Lehet: public, mod, admin, owner");
            }
            await setRolePermission(message.guild.id,role.id,level);
            message.reply(`A **${role.name}** rang mostantól **${level}** jogosultságú`);

    {
        name: 'loglist',
        description: 'Dátumon belül ki listáza a log eredményeit.',
        permissionLevel: 'admin',
        async prefix(message, args){
            const targetChannel = await getCommandTargetChannel(message, 'loglist');

            let start = "";
            let end = "";

            if(!args[0]){
                await targetChannel.send("Használat: !loglist 2026-03-08 vagy !loglist 2026-03-07 2026-03-08");
                return;
            }

            if(!args[1]){
                start = args[0] + " 00:00:00";
                end = args[0] + " 23:59:59";
            }else if(!args[2]){
                start = args[0] + " " + args[1];
                end = args[0] + " 23:59:59";
            }
            else if(!args[3]){
                start = args[0] + " " + args[1];
                end = args[2] + " 23:59:59";
            }else {
                start = args[0] + " " + args[1];
                end = args[2] + " " + args[3];
            }

            const logs = await getLogsBetween(start,end);

            if(!logs.length){
                await targetChannel.send("nincs log ebben az időszakban");
                return;
            }

            let text = "logok: \n\n";
            for(const log of logs.slice(0,10)){
                text += `[${log.created_at}]${log.type} - ${log.message}\n`;
            }

            await targetChannel.send("```"+text+"```");
        },
        async slash(interaction){
            const startDate = interaction.options.getString('start');
            const endDate = interaction.options.getString('end') || startDate;

            if(!startDate){
                await interaction.reply({
                    content: 'Adj meg egy dátumot. Példa: 2026-03-08 és a !loglist parancsot használd!',
                    ephemeral: true
                });
                return;
            }

            const start = startDate + " 00:00:00";
            const end = endDate + " 23:59:59";

            const logs = await getLogsBetween(start,end);

            if(!logs.length){
                await interaction.reply({
                    content: "Nincs log ebben az időszakban.",
                    ephemeral: true
                });
                return;
            }

            let text = "Logok:\n\n";

            for(const log of logs.slice(0,10)){
                text += `[${log.created_at}] ${log.type} - ${log.message}\n`;
            }

            await interaction.reply({
                content: "```"+text+"```",
                ephemeral: true
            });
        }

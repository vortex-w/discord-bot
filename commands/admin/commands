    {
        name: 'loglist',
        description: 'Dátumon belül ki listáza a log eredményeit.',
        permissionLevel: 'admin',
        async prefix(message, args){
            //console.log("itt vagyunk");
            if(!args[0]){
                await message.reply("Használat: !loglist 2026-03-08 vagy !loglist 2026-03-07 2026-03-08");
                return;
            }
            let start = args[0];
            let start_time = args[1];
            let end = args[2] || args[0];
            let end_time = args[2];
            //console.log(start.length);
            
            start = start + " 00:00:00";    
            end = end + " 23:59:59";

            const logs = await getLogsBetween(start,end);
            //console.log("start:", start, "end:",end);
            if(!logs.length){
                await message.reply("nincs log ebben az időszakban");
                return;
                
            }

            let text = "logok: \n\n";
            for(const log of logs.slice(0,10)){
                text +=`[${log.created_at}]${log.type} - ${log.message}\n`;
            }

            await message.reply("```"+text+"```");
        },
        async slash(interaction){

            const startDate = interaction.options.getString('start');
            const endDate = interaction.options.getString('end') || startDate;

            if(!startDate){
                await interaction.reply({
                    content: 'Adj meg egy dátumot. Példa: 2026-03-08',
                    ephemeral: true
                });
                return;
            }

            const start = startDate + " 00:00:00";
            const end = endDate + " 23:59:59";

            const logs = await getLogsBetween(start,end);

            if(!logs.length){
                await interaction.reply({
                    content: "Nincs log ebben az időszakban.",
                    ephemeral: true
                });
                return;
            }

            let text = "Logok:\n\n";

            for(const log of logs.slice(0,10)){
                text += `[${log.created_at}] ${log.type} - ${log.message}\n`;
            }

            await interaction.reply({
                content: "```"+text+"```",
                ephemeral: true
            });

        }
    }
];
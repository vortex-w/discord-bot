    {
        name : 'tagjogok',
        description : 'Adott tagnak megmutatja milyen extra parancsai vannak',
        permissionLevel :'admin',
        async prefix(message, args){
            const user = message.mentions.users.first();

            if(!user){
                return message.channel.send("Adj meg egy felhasználót. Példa: !tagjogok @user");
            }
            const perms = await getUserCommandPermission(
                message.guild.id,
                user.id
            ) || [];
            //console.log(perms);
            if(!perms.length){
                return message.channel.send(`${user.username} nem rendelkezik extra parancsokkal.`);
            }
            let text = `${user.username} extra parancsai:\n\n`;
            let state = "";
            
            for(const perm of perms){
                if(perm.allowed==1){
                state = "igen";
                }else{
                    state = "Nem";
                }
                text += `${perm.command_name} Aktív:${state}\n`;
            }
            message.channel.send("```"+text+"```");
        }

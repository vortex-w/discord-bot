    {
        name : 'setrole',
        description: 'Rang jogosultság beállítása',
        permissionLevel: 'admin',

        async prefix(message,args){
            const allowedLevels = ['public', 'mod', 'admin', 'owner'];
            const role = message.mentions.roles.first();
            const level = args[1]?.toLowerCase();
            if(!role){
                return message.channel.send("Adj meg egy rangot. Pl: !setrole @moderátor mod");
            }
            if(!level){
                return message.channel.send("Adj meg egy jogosultsági szintent.");
            }
            if(!allowedLevels.includes(level)){
                return message.channel.send("Érvénytelen jogosultsági szint. Lehet: public, mod, admin, owner");
            }
            await setRolePermission(message.guild.id,role.id,level);
            message.channel.send(`A **${role.name}** rang mostantól **${level}** jogosultságú`);
        }
    },
    {
        name : 'parancstarsitas',
        description: 'Engedélyez egy parancsot egy usernek',
        permissionLevel: 'admin',

        async prefix(message,args){
            const user = message.mentions.users.first();
            const commandName = args[1]?.toLowerCase();
            if(!user){
                return message.channel.send("Adj meg egy felhasználót. Példa: !parancstarsitas @user parancs");

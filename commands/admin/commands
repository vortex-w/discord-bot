    {
        name : 'setcsatorna',
        description : 'Használat: !setcsatorna [remove, add, list, show]; csatornaneve; parancs neve',
        permissionLevel : 'admin',

        async prefix(message, args, client){
            const targetChannel = await getCommandTargetChannel(message, 'setcsatorna');
            const raw = args.join(" ").trim();

            if(!raw){
                return targetChannel.send(
                    'Használat:\n' +
                    '!setcsatorna add; csatornanév; parancsnév\n' +
                    '!setcsatorna remove; csatornanév; parancsnév\n' +
                    '!setcsatorna show; parancsnév\n' +
                    '!setcsatorna list'
                );
            }

            const parts = raw.split(";").map(p => p.trim()).filter(p => p.length > 0);
            const action = (parts[0] || "").toLowerCase();

            if(action === "list"){
                const rows = await getAllCommandChannelRules(message.guild.id);

                if(!rows || rows.length === 0){
                    return targetChannel.send("Nincs beállított parancs-csatorna hozzárendelés.");
                }

                const text = rows
                    .map(row => `${row.command_name} --> <#${row.channel_id}>`)
                    .join("\n");

                return targetChannel.send(`Beállított hozzárendelések:\n${text}`);
            }

            if(action === "show"){
                const commandName = parts[1];

                if(!commandName){
                    return targetChannel.send("Használat: !setcsatorna show; parancsnév");
                }

                const rows = await getCommandChannels(message.guild.id, commandName);

                if(!rows || rows.length === 0){
                    return targetChannel.send(`A(z) **${commandName}** parancshoz nincs csatorna rendelve.`);
                }

                const text = rows
                    .map(row => `<#${row.channel_id}>`)
                    .join("\n");

                return targetChannel.send(`A(z) **${commandName}** parancs csatornái:\n${text}`);
            }

            if(action !== "add" && action !== "remove"){
                return targetChannel.send("Ismeretlen művelet. Használat: add | remove | show | list");
            }

            const channelName = parts[1];
            const commandName = parts[2];

            if(!channelName || !commandName){
                return targetChannel.send(
                    'Használat:\n' +
                    '!setcsatorna add; csatornanév; parancsnév\n' +
                    '!setcsatorna remove; csatornanév; parancsnév'
                );
            }

            if(!client.commands.has(commandName)){
                return targetChannel.send(`A(z) **${commandName}** parancs nem létezik.`);
            }

            const channel = await getGuildChannelByName(message.guild.id, channelName);

            if(!channel){
                return targetChannel.send(`Nem találom ezt a csatornát az adatbázisban: **${channelName}**`);
            }

            try{
                if(action === "add"){
                    await addCommandChannel(message.guild.id, commandName, channel.channel_id);
                    return targetChannel.send(`A(z) **${commandName}** parancs hozzá lett rendelve ehhez: **${channel.channel_name}**`);
                }

                if(action === "remove"){
                    await removeCommandChannel(message.guild.id, commandName, channel.channel_id);
                    return targetChannel.send(`A(z) **${commandName}** parancs el lett távolítva innen: **${channel.channel_name}**`);
                }
            }catch (err){
                await logError(err,'Hiba a feltöltés vagy törlés során');
            }
        }
    },
    {
        name: 'verziofrissitve',
        description: 'Beállítja a bot jelenlegi verzióját. Használat: !verziofrissitve V1.4.0',
        permissionLevel: 'admin',

        async prefix(message, args){
            const targetChannel = await getCommandTargetChannel(message, 'verziofrissitve');

            const version = args[0];

            if(!version){
                return targetChannel.send("Használat: `!verziofrissitve V1.4.0`");
            }

            if(!/^V\d+\.\d+\.\d+$/i.test(version)){
                return targetChannel.send("Hibás verzió formátum. Példa: `V1.4.0`");
            }

            const cleanVersion = version.toUpperCase();

            await getOrCreateBotVersion(message.guild.id);
            await updateCurrentBotVersion(message.guild.id, cleanVersion);

            const github = await getGithubVersion();

            const result = compareVersions(
                cleanVersion,
                github.version
            );

            let statusText = "";

            if(result.type === 'same'){
                statusText = "✅ A bot verziója most naprakész.";
            }else{
                statusText = `ℹ️ Beállítva, de a GitHub verzió jelenleg: ${github.version}`;
            }

            await targetChannel.send(
                `✅ Verzió frissítve az adatbázisban.\n\n` +
                `Új helyi verzió: ${cleanVersion}\n` +
                `GitHub verzió: ${github.version}\n` +
                `${statusText}`
            );
        }
    }
